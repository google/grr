  args { signed: "--logger_min_status=3" }  # Disable status logs.
  args { signed: "--logger_min_stderr=2" }  # Enable only `ERROR`-level logs to stderr.

  env_vars_inherited: "SystemRoot"

  unsigned_stdin_allowed: true
}

